{
  "info": {
    "name": "Restaurante-ServerAdmin",
    "description": "Colección de Postman para probar el microservicio de ServerAdmin usando datos del seeder.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "Get All Companies",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies",
              "host": ["{{base_url}}"],
              "path": ["companies"]
            }
          }
        },
        {
          "name": "Get Company (Pollo Campero)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies/c00000000000000000000001",
              "host": ["{{base_url}}"],
              "path": ["companies", "c00000000000000000000001"]
            }
          }
        }
      ]
    },
    {
      "name": "Branches",
      "item": [
        {
          "name": "Get Branches (Pollo Campero)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/branches?companyId=c00000000000000000000001",
              "host": ["{{base_url}}"],
              "path": ["branches"],
              "query": [
                { "key": "companyId", "value": "c00000000000000000000001" }
              ]
            }
          }
        },
        {
          "name": "Get Branch Details (Campero Zona 1)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/branches/b00000000000000000000011",
              "host": ["{{base_url}}"],
              "path": ["branches", "b00000000000000000000011"]
            }
          }
        }
      ]
    },
    {
      "name": "Menus",
      "item": [
        {
          "name": "Get Menus (Campero Zona 1)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/menus?branch=b00000000000000000000011",
              "host": ["{{base_url}}"],
              "path": ["menus"],
              "query": [
                { "key": "branch", "value": "b00000000000000000000011" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get Orders (Campero Zona 1)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/orders?branchId=b00000000000000000000011",
              "host": ["{{base_url}}"],
