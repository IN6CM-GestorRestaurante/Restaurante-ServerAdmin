                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  const d = pm.response.json();",
                      "  const id = d.order?._id;",
                      "  if (id) pm.environment.set('ID_ORDER', id);",
                      "  const items = d.order?.items;",
                      "  if (items && items.length) pm.environment.set('ID_ORDER_ITEM', items[0]._id);",
